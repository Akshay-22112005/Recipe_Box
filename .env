# MongoDB connection string

MONGODB_URI=mongodb://127.0.0.1:27017/recipe-box

# Backend server port
PORT=5000

# Cloudinary (optional — omit these to use local disk storage for uploads)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
